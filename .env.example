# ============================================================================
# Telecom Operations Dashboard - Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your deployment
# For local development, use defaults; for production, use Azure PostgreSQL
# ============================================================================

# ---- Azure PostgreSQL Configuration ----
# Example: telecom-db.postgres.database.azure.com
DB_HOST=localhost

# PostgreSQL port (default 5432)
DB_PORT=5432

# Database name
DB_NAME=milan_telecom

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=postgres

# SSL mode: 
# - 'disable' for local development
# - 'require' for Azure PostgreSQL (mandatory)
DB_SSL_MODE=disable

# ---- Producer Service Configuration ----
# Poll interval in milliseconds (default: 15 minutes)
PRODUCER_POLL_INTERVAL_MS=900000

# Simulation page send timeout in seconds
APP_SIMULATION_PAGE_SEND_TIMEOUT_SECONDS=30

# ---- Keycloak Configuration ----
# (Already configured with defaults in docker-compose.yml)
# Keycloak admin password
KEYCLOAK_ADMIN_PASSWORD=admin

# Gateway service secret (change in production!)
KEYCLOAK_CLIENT_SECRET=change-me

# ---- Grafana Configuration ----
# Grafana admin password
GRAFANA_PASSWORD=admin

# ---- Optional: Docker User/Group IDs ----
# Use your current user/group for volume permissions
# Run: id -u && id -g
UID=1000
GID=1000
