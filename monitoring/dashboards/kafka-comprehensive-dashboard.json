{
  "uid": "kafka-comprehensive",
  "title": "Kafka - Cluster, Broker & Topic",
  "tags": ["kafka", "cluster", "broker", "topic"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Cluster Health Overview",
      "type": "row",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Brokers Online",
      "type": "stat",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_controller_kafkacontroller_activebrokercount)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 3}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Controllers",
      "type": "stat",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_controller_kafkacontroller_activecontrollercount)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1},
              {"color": "red", "value": 2}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Under-Replicated Partitions",
      "type": "stat",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_server_replicamanager_underreplicatedpartitions)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Offline Partitions",
      "type": "stat",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_controller_kafkacontroller_offlinepartitionscount)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Total Topics",
      "type": "stat",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_controller_kafkacontroller_globaltopiccount)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Partitions",
      "type": "stat",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_controller_kafkacontroller_globalpartitioncount)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Broker Metrics",
      "type": "row",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Broker Disk Activity",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(kafka_server_kafkaserver_linux_disk_read_bytes[1m])",
          "legendFormat": "Read Rate - {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Disk I/O Rate by Broker",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 6, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(kafka_server_kafkaserver_linux_disk_read_bytes[1m])",
          "legendFormat": "Read - {{instance}}",
          "refId": "A"
        },
        {
          "expr": "rate(kafka_server_kafkaserver_linux_disk_write_bytes[1m])",
          "legendFormat": "Write - {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Broker CPU/Memory",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 6, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"kafka\"}",
          "legendFormat": "CPU {{instance}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"kafka\"} / jvm_memory_max_bytes{area=\"heap\", job=\"kafka\"}",
          "legendFormat": "Heap % {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 12,
      "title": "Topic Metrics",
      "type": "row",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Replica Manager State",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_server_replicamanager_partitioncount",
          "legendFormat": "Total Partitions - {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "gradientMode": "hue"
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Network Processor Performance",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_network_socketserver_networkprocessoravgidlepercent",
          "legendFormat": "Idle % - {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Offline Replica Count",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_server_replicamanager_offlinereplicacount",
          "legendFormat": "Offline Replicas",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Leader Partition Distribution",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_server_replicamanager_leadercount",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 17,
      "title": "Network & Performance",
      "type": "row",
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 18,
      "title": "Request Queue Size",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 32, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_network_requestchannel_requestqueuesize",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 19,
      "title": "Response Queue Size",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 32, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_network_requestchannel_responsequeuesize",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 20,
      "title": "ISR Partitions (Min/Under Min)",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 32, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_server_replicamanager_atminisrpartitioncount",
          "legendFormat": "At Min ISR - {{instance}}",
          "refId": "A"
        },
        {
          "expr": "kafka_server_replicamanager_underminisrpartitioncount",
          "legendFormat": "Under Min ISR - {{instance}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "version": 1,
  "time": {"from": "now-1h", "to": "now"},
  "id": null
}